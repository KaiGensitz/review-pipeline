%% https://mermaid.live/ to render

flowchart TD
  %% Styles
  classDef proc fill:#e1f5fe,stroke:#01579b,stroke-width:2px,color:#000;
  classDef dec fill:#fff9c4,stroke:#fbc02d,stroke-width:2px,color:#000;
  classDef inp fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#000;
  classDef out fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px,color:#000;
  classDef cfg fill:#eceff1,stroke:#455a64,stroke-width:2px,color:#000;
  classDef human fill:#ffe0b2,stroke:#e65100,stroke-width:2px,color:#000;
  classDef metric fill:#ede7f6,stroke:#5e35b1,stroke-width:2px,color:#000;

  %% Inputs & config
  Icsv["Project data\n(CSV exports)"]:::inp
  Ikb["Reference examples\n(POS/NEG snippets)"]:::inp
  Ipdf["Documents\n(PDFs if needed)"]:::inp
  Cfg["Run settings\n(simple config)"]:::cfg

  %% Stage swimlanes
  subgraph TA["Step 1"]
    direction LR
    TA_stage["Load CSV + examples"]:::proc
    TA_qc{Take deterministic 10% QC sample}:::dec
    TA_ai["AI screens QC list"]:::proc
    TA_hum["4 blinded humans in Covidence\nDropdown study tags; Notes ignored"]:::human
    TA_val{Compare to human gold\nSens>0.95; Spec 0.40-0.80; PABAK>0.80}:::metric
    TA_refine["Prompt refinement loop"]:::proc
    TA_full["AI labels remaining 90%"]:::proc
    TA_out["Decisions + logs"]:::out
  end

  subgraph FT["Step 2"]
    direction LR
    FT_stage["Load next CSVs + PDFs"]:::proc
    FT_qc{Take deterministic 10% QC sample}:::dec
    FT_ai["AI screens QC list"]:::proc
    FT_hum["4 blinded humans in Covidence\nDropdown study tags; Notes ignored"]:::human
    FT_val{Compare to human gold\nSens>0.95; Spec 0.40-0.80; PABAK>0.80}:::metric
    FT_refine["Prompt refinement loop"]:::proc
    FT_full["AI labels remaining 90%"]:::proc
    FT_out["Decisions + logs"]:::out
  end

  subgraph DE["Step 3"]
    direction LR
    DE_stage["Load final CSVs + PDFs"]:::proc
    DE_qc{Take deterministic 10% QC sample}:::dec
    DE_ai["AI extracts QC list"]:::proc
    DE_hum["4 blinded humans in Covidence\nExtraction gold standard"]:::human
    DE_val{Compare to human gold\nConcordance>0.80; Accuracy>0.90}:::metric
    DE_refine["Prompt refinement per field"]:::proc
    DE_full["AI extracts remaining 90%"]:::proc
    DE_out["Extraction + logs"]:::out
  end

  %% Global flow
  Icsv --> TA_stage
  Ikb --> TA_stage
  Cfg -. settings .-> TA_stage

  TA_stage --> TA_qc
  TA_qc -- yes --> TA_ai
  TA_qc -- yes --> TA_hum
  TA_ai --> TA_val
  TA_hum --> TA_val
  TA_val -- fail --> TA_refine
  TA_refine --> TA_qc
  TA_val -- pass --> TA_full
  TA_full --> TA_out

  TA_out --> FT_stage
  Ipdf -. doc files .-> FT_stage
  Ikb --> FT_stage
  Cfg -. settings .-> FT_stage

  FT_stage --> FT_qc
  FT_qc -- yes --> FT_ai
  FT_qc -- yes --> FT_hum
  FT_ai --> FT_val
  FT_hum --> FT_val
  FT_val -- fail --> FT_refine
  FT_refine --> FT_qc
  FT_val -- pass --> FT_full
  FT_full --> FT_out

  FT_out --> DE_stage
  Ikb --> DE_stage
  Cfg -. settings .-> DE_stage
  Ipdf -. doc files .-> DE_stage

  DE_stage --> DE_qc
  DE_qc -- yes --> DE_ai
  DE_qc -- yes --> DE_hum
  DE_ai --> DE_val
  DE_hum --> DE_val
  DE_val -- fail --> DE_refine
  DE_refine --> DE_qc
  DE_val -- pass --> DE_full
  DE_full --> DE_out

  %% Aggregation & release
  TA_out --> RL["Resource logs\n(tokens / energy)"]:::out
  FT_out --> RL
  DE_out --> RL

  TA_out --> Agg["Aggregate decision outputs"]:::proc
  FT_out --> Agg
  DE_out --> Agg
  

  class TA_stage,TA_ai,TA_refine,TA_full,FT_stage,FT_ai,FT_refine,FT_full,DE_stage,DE_ai,DE_refine,DE_full,Agg proc;
  class TA_qc,FT_qc,DE_qc dec;
  class TA_hum,FT_hum,DE_hum human;
  class TA_val,FT_val,DE_val metric;