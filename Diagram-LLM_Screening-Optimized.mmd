# https://mermaid.live/ to render

flowchart TD
  %% Styles
  classDef proc fill:#e1f5fe,stroke:#01579b,stroke-width:2px,color:#000;
  classDef dec fill:#fff9c4,stroke:#fbc02d,stroke-width:2px,color:#000;
  classDef inp fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#000;
  classDef out fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px,color:#000;
  classDef cfg fill:#eceff1,stroke:#455a64,stroke-width:2px,color:#000;

  %% Inputs & config
  Icsv["Project data\n(CSV exports)"]:::inp
  Ikb["Reference examples\n(POS/NEG snippets)"]:::inp
  Ipdf["Documents\n(PDFs if needed)"]:::inp
  Cfg["Run settings\n(simple config)"]:::cfg

  %% Stage swimlanes
  subgraph TA["Step 1"]
    direction LR
    TA_stage["Load CSV + examples"]:::proc
    TA_qc{Take 10% sample?}:::dec
    TA_ai["AI labels sample"]:::proc
    TA_val{Sample ok vs humans?}:::dec
    TA_full["AI labels rest"]:::proc
    TA_out["Decisions + logs"]:::out
  end

  subgraph FT["Step 2"]
    direction LR
    FT_stage["Load next CSVs + PDFs"]:::proc
    FT_qc{Take 10% sample?}:::dec
    FT_ai["AI labels sample"]:::proc
    FT_val{Sample ok vs humans?}:::dec
    FT_full["AI labels rest"]:::proc
    FT_out["Decisions + logs"]:::out
  end

  subgraph DE["Step 3"]
    direction LR
    DE_stage["Load final CSVs + PDFs"]:::proc
    DE_qc{Take 10% sample?}:::dec
    DE_ai["AI extracts sample"]:::proc
    DE_val{Sample ok vs humans?}:::dec
    DE_full["AI extracts rest"]:::proc
    DE_out["Extraction + logs"]:::out
  end

  %% Global flow
  Icsv --> TA_stage
  Ikb --> TA_stage
  Cfg -. settings .-> TA_stage

  TA_stage --> TA_qc
  TA_qc -- yes --> TA_ai
  TA_ai --> TA_val
  TA_val -- pass --> TA_full
  TA_val -- fail --> TA_qc
  TA_full --> TA_out

  TA_out --> FT_stage
  Ipdf -. doc files .-> FT_stage
  Ikb --> FT_stage
  Cfg -. settings .-> FT_stage

  FT_stage --> FT_qc
  FT_qc -- yes --> FT_ai
  FT_ai --> FT_val
  FT_val -- pass --> FT_full
  FT_val -- fail --> FT_qc
  FT_full --> FT_out

  FT_out --> DE_stage
  Ikb --> DE_stage
  Cfg -. settings .-> DE_stage
  Ipdf -. doc files .-> DE_stage

  DE_stage --> DE_qc
  DE_qc -- yes --> DE_ai
  DE_ai --> DE_val
  DE_val -- pass --> DE_full
  DE_val -- fail --> DE_qc
  DE_full --> DE_out

  %% Aggregation & release
  TA_out --> RL["Resource logs\n(tokens / energy)"]:::out
  FT_out --> RL
  DE_out --> RL

  TA_out --> Agg["Aggregate outputs"]:::proc
  FT_out --> Agg
  DE_out --> Agg
  Agg --> Pub["Release code + validated datasets\n(CC-BY-NC-SA)"]:::out

  class TA_stage,TA_ai,TA_full,FT_stage,FT_ai,FT_full,DE_stage,DE_ai,DE_full,Agg proc;
  class TA_qc,TA_val,FT_qc,FT_val,DE_qc,DE_val dec;
